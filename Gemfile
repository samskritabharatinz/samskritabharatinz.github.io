# This file is only needed if you want to preview the site on your own
# computer before publishing. GitHub Pages does NOT need it to build the
# live site. If you never preview locally, you can ignore this file.
#
# To preview locally (once Ruby is installed):
#   bundle install
#   bundle exec jekyll serve
# then open http://localhost:4000

source "https://rubygems.org"

# Matches the exact set of gems GitHub Pages runs, so a local preview
# behaves the same as the live site.
gem "github-pages", group: :jekyll_plugins

gem "webrick", "~> 1.8"
